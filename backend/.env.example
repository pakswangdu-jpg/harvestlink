# Copy this file to .env and fill in real values for local development.
# In Render, set these as environment variables in the service dashboard instead —
# never commit a real .env file (it's already gitignored).

# Supabase Dashboard -> Settings -> API -> Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Dashboard -> Settings -> API -> service_role secret key
# Full-access key — server-side only, NEVER expose this to the frontend.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# The deployed frontend origin allowed to call this API (CORS). For local dev
# this is the Vite dev server; in Render, set it to your Vercel URL.
CORS_ALLOWED_ORIGIN=http://localhost:5173

# Render injects PORT automatically in production — this is only used locally.
PORT=4000

# OpenWeatherMap -> API keys tab (https://home.openweathermap.org/api_keys).
# Powers the Demand Forecast dashboard's real weather data (backend/src/lib/weatherService.js).
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key

# Gemini -> https://aistudio.google.com/apikey
# Powers the Demand Forecast dashboard's plain-language AI market analysis/recommendation
# (backend/src/lib/geminiService.js). The forecast price/demand numbers themselves never
# come from Gemini — they're always computed by priceForecastEngine.js/forecastEngine.js
# from real data — this key only unlocks the narrative explanation of an already-computed
# forecast. Without it, aiSummary/aiRecommendation are simply null (the rest of the
# dashboard still works).
GEMINI_API_KEY=your-gemini-api-key

# PayMongo Dashboard -> Developers -> API Keys -> Secret key.
# Server-side only, NEVER expose this to the frontend. Powers real GCash payments
# (backend/src/lib/paymongoService.js / payments.controller.js).
PAYMONGO_SECRET_KEY=your-paymongo-secret-key

# PayMongo Dashboard -> Developers -> Webhooks -> Add endpoint, pointed at
# <this-backend's-public-URL>/api/payments/gcash/webhook, subscribed to payment.paid and
# payment.failed. PayMongo shows the endpoint's secret_key once, at creation — paste it here.
# Needs a publicly reachable URL, so this can only be set up after deploying (e.g. to Render);
# it can't be exercised against localhost. Without it, webhook deliveries are rejected
# (signature won't verify) — payments still get confirmed via the buyer's own return-page
# visit (confirmGcashPayment), just without the extra redundancy for a buyer who never
# returns to the tab.
PAYMONGO_WEBHOOK_SECRET=your-paymongo-webhook-secret
