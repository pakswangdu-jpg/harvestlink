# Copy this file to .env and fill in real values for local development.
# In Render, set these as environment variables in the service dashboard instead —
# never commit a real .env file (it's already gitignored).

# Supabase Dashboard -> Settings -> API -> Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Dashboard -> Settings -> API -> service_role secret key
# Full-access key — server-side only, NEVER expose this to the frontend.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# The deployed frontend origin allowed to call this API (CORS). For local dev
# this is the Vite dev server; in Render, set it to your Vercel URL.
CORS_ALLOWED_ORIGIN=http://localhost:5173

# Render injects PORT automatically in production — this is only used locally.
PORT=4000
