# Copy this file to .env and fill in real values for local development.
# In Vercel, set these as environment variables in the project dashboard instead —
# never commit a real .env file (it's already gitignored).

# Google Cloud Console -> APIs & Services -> Credentials. Needs the Maps JavaScript API and
# Geocoding API enabled, billing enabled on the project, and (recommended) the key
# restricted to your site's HTTP referrers.
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Supabase Dashboard -> Settings -> API -> Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Dashboard -> Settings -> API -> anon public key (safe to expose client-side —
# Row Level Security on every table blocks it from reading/writing anything on its own;
# see supabase/schema.sql)
VITE_SUPABASE_ANON_KEY=your-anon-key

# The deployed backend's base URL, including /api. For local dev this is the Express
# server started via `cd backend && npm run dev` (see backend/README.md).
VITE_API_URL=http://localhost:4000/api
